# ACN environment — TEMPLATE. Copy to `.env` (gitignored) and fill real values.
# Names only here; never commit real secrets.
# The shared salt is the most sensitive secret in the system and
# must never reach source, Drive, Kafka, Neo4j, logs, or the UI.

# --- Pseudonymisation ---
# HMAC key for account hashing. Most sensitive secret. Rotating it re-derives all hashes.
ACN_SHARED_SALT=change-me-long-random-secret

# --- Institution identity (services) ---
# Which institution this process acts as: INST_A | INST_B | INST_C | INST_D | INST_E
ACN_INST_ID=INST_A

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- Redis (AOF enabled) ---
REDIS_URL=redis://redis:6379/0

# --- Kafka (mTLS listener only) ---
KAFKA_BROKER=kafka:9093
# Per-institution mTLS material (PEM for confluent-kafka python clients).
KAFKA_SSL_CAFILE=./certs/kafka/ca-cert.pem
KAFKA_SSL_CERTFILE=./certs/kafka/INST_A-cert.pem
KAFKA_SSL_KEYFILE=./certs/kafka/INST_A-key.pem

# --- Ollama (server-side only; never exposed to the browser) ---
# Used for STR drafting only.
OLLAMA_HOST=http://ollama:11434
OLLAMA_STR_MODEL=llama3.1:8b

# --- ML reproducibility ---
# Active seed for a run — one of 42 | 123 | 456 | 789 | 1024.
RANDOM_SEED=42

# --- Observability ---
ACN_LOG_LEVEL=INFO
# Injected at deploy for /health "version"; leave blank locally.
ACN_GIT_SHA=
