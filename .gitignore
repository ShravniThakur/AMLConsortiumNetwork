# OS
.DS_Store

# Secrets / environment — never commit
.env
.env.local
*.key
*.salt
*.share
# All mTLS material (PEM, JKS keystores/truststores, credential + serial files) is
# generated by scripts/gen_certs.sh and must never be committed. Keep the dir tracked.
certs/*
!certs/.gitkeep
certs/kafka/client-ssl.properties

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/
.coverage
htmlcov/

# Notebooks
.ipynb_checkpoints/

node_modules/

# The local `acn-data/` root — the single home for all local artefacts (raw CSVs, splits,
# GNN models, logs). NEVER commit: contains raw data. Everything the pipeline reads/writes
# lives under here.
/acn-data/

# Belt-and-suspenders: keep large artefact types out of git wherever they land.
*.pt
*.pkl
*.parquet
*.csv
*.jsonl
